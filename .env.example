# --- Veritabani (Vercel Postgres) ---
# Yerelde: docker-compose ile Postgres (adapter localhost'u algilayip pg'ye gecer)
# Uretimde: Vercel Postgres bu degiskeni otomatik saglar.
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/ozden

# --- Payload ---
PAYLOAD_SECRET=degistir_bu_gizli_anahtari

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://ozdenozgurdurukan.com
TZ=Europe/Istanbul

# --- Medya deposu (Vercel Blob) ---
# Uretimde Vercel Blob store olusturulunca otomatik gelir. Bos ise yerelde diske yazilir.
BLOB_READ_WRITE_TOKEN=

# --- E-posta (Resend) — Faz 3 ---
RESEND_API_KEY=

# --- SMS (NetGSM) — Faz 3 ---
NETGSM_USERNAME=
NETGSM_PASSWORD=
NETGSM_HEADER=

# --- WhatsApp (Meta Cloud API) — Faz 3 ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- MCP (21st.dev Magic) — .mcp.json tarafindan okunur ---
TWENTYFIRST_API_KEY=
